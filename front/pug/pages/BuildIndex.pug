.land
    a.global-link(href="https://tinyurl.com/3utxmdjt")
    .popup(data-popup-container="popup")
        .popup__wrapper 
            .popup__top 
                canvas(data-canvas="popup")
            .popup__bottom
                .popup__title 
                    h2.popup__title-item Вітаємо
                    h2.popup__title-item Ти добіг до бонусу
                .popup__subtitle 
                    span.popup__subtitle-item 390 000 ₴
                    span.popup__subtitle-item 600 FS
                a.popup__btn(href="https://tinyurl.com/3utxmdjt") Забрати бонус
            .popup__decor 
                .popup__decor-left
                    .popup__decor-left-item
                        img(src="./img/popup/decor/decor-1-left.png" alt="favbet")
                    .popup__decor-left-item
                        img(src="./img/popup/decor/decor-2-left.png" alt="favbet")
                    .popup__decor-left-item
                        img(src="./img/popup/decor/decor-3-left.png" alt="favbet")
                    .popup__decor-left-item
                        img(src="./img/popup/decor/decor-4-left.png" alt="favbet")
                .popup__decor-right
                    .popup__decor-right-item
                        img(src="./img/popup/decor/decor-1-right.png" alt="favbet")
                    .popup__decor-right-item
                        img(src="./img/popup/decor/decor-2-right.png" alt="favbet")
                    .popup__decor-right-item
                        img(src="./img/popup/decor/decor-3-right.png" alt="favbet")
                    .popup__decor-right-item
                        img(src="./img/popup/decor/decor-4-right.png" alt="favbet")

    .land__left
        .land__logo
            img(src="./img/logo.png" alt="favbet")
        .land__title 
            h2.land__title-item біжи
            h2.land__title-item у своєму ритмі
        span.land__subtitle за бонусом
        .land__counter 
            .land__counter-number 0 / 4
            span.land__counter-text Дорога до бонусу
        a.land__btn.btn(href="https://tinyurl.com/3utxmdjt") Реєстрація
        ul.license
            li.license__item
                img(src="./img/visa.svg" alt="favbet")
            li.license__item
                img(src="./img/mastercard.svg" alt="favbet")
            li.license__item
                img(src="./img/googlePay.svg" alt="favbet")
            li.license__item
                img(src="./img/applePay.svg" alt="favbet")
            li.license__item
                img(src="./img/coinspaid.svg" alt="favbet")
    .land__canvas
        canvas(data-canvas="chicken")
        button.land__canvas-btn(data-canvas-init="chicken") вперед
    
            
